<div class="page-width">
  <h1>Search</h1>

  <!-- Search Form -->
  <form action="{{ routes.search_url }}" method="get" class="search-form">
    <input
      type="search"
      name="q"
      value="{{ search.terms }}"
      placeholder="Search products..."
    >
    <button type="submit">Search</button>
  </form>

  {% if search.performed %}
    <h2>Results for "{{ search.terms }}" ({{ search.results_count }})</h2>

    {% if search.results_count > 0 %}
      <div class="search-grid">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            <div class="product-card">
              <a href="{{ item.url }}">
                {% if item.featured_image %}
                  {{ item.featured_image | image_url: width: 400 | image_tag }}
                {% endif %}

                <h3>{{ item.title }}</h3>

                <p>{{ item.price | money }}</p>
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>

    {% else %}
      <p>No results found.</p>
    {% endif %}
  {% endif %}
</div>

<style>
  .search-form {
    margin-bottom: 30px;
  }

  .search-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .product-card img {
    width: 100%;
  }

  .product-card h3 {
    font-size: 16px;
  }
</style>
