<section class="error-404">
  <div class="page-width">
    <div class="error-404__content">
      <h1 class="error-404__title">404</h1>

      <h2 class="error-404__subtitle">
        {{ section.settings.heading }}
      </h2>

      <p class="error-404__text">
        {{ section.settings.text }}
      </p>

      <a href="{{ routes.root_url }}" class="error-404__btn">
        {{ section.settings.button_text }}
      </a>
    </div>
  </div>
</section>

<style>
  .error-404 {
    text-align: center;
    padding: 100px 20px;
  }

  .error-404__title {
    font-size: 120px;
    font-weight: 700;
    margin: 0;
  }

  .error-404__subtitle {
    font-size: 28px;
    margin-top: 10px;
  }

  .error-404__text {
    margin-top: 15px;
    color: #666;
  }

  .error-404__btn {
    display: inline-block;
    margin-top: 25px;
    padding: 12px 28px;
    background: black;
    color: white;
    text-decoration: none;
    border-radius: 4px;
  }

  .error-404__btn:hover {
    opacity: 0.85;
  }
</style>

{% schema %}
{
  "name": "404 Page",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page not found"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Sorry, the page you are looking for does not exist."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Return to homepage"
    }
  ],
  "presets": [
    {
      "name": "404 Page"
    }
  ]
}
{% endschema %}
