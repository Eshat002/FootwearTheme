<div class="page-width">
  <h1>Your Cart ({{ cart.item_count }})</h1>

  {% if cart.item_count > 0 %}
    <form action="/cart" method="post" novalidate>
      <table class="cart-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
            <th>Remove</th>
          </tr>
        </thead>

        <tbody>
          {% for item in cart.items %}
            <tr>
              <td class="cart-product">
                {{ item.image | image_url: width: 100 | image_tag }}
                <div>
                  <p>{{ item.product.title }}</p>
                  <small>{{ item.variant.title }}</small>
                </div>
              </td>

              <td>
                {{ item.price | money }}
              </td>

              <td>
                <input
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                >
              </td>

              <td>
                {{ item.line_price | money }}
              </td>

              <td>
                <a
                  href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0"
                  class="remove-btn"
                >
                  Remove
                </a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div class="cart-summary">
        <p>Total Items: {{ cart.item_count }}</p>

        <h3>Subtotal</h3>
        <p>{{ cart.total_price | money }}</p>

        <button
          type="submit"
          name="update"
          class="btn"
        >
          Update Cart
        </button>

        <button
          type="submit"
          name="checkout"
          class="btn btn-primary"
        >
          Proceed to Checkout
        </button>
      </div>
    </form>
  {% else %}
    <p>Your cart is empty.</p>
  {% endif %}
</div>

<style>
  .cart-table {
    width: 100%;
    border-collapse: collapse;
  }

  .cart-table th,
  .cart-table td {
    padding: 15px;
    border-bottom: 1px solid #eee;
  }

  .cart-product {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .cart-summary {
    margin-top: 30px;
    text-align: right;
  }

  .btn {
    padding: 10px 18px;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background: black;
    color: white;
  }

  .remove-btn {
    color: red;
    text-decoration: none;
    font-size: 14px;
  }

  .remove-btn:hover {
    text-decoration: underline;
  }
</style>
